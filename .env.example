# ============================================================
# CodeGuardian AI — Environment Configuration Template
# Copy to .env and fill in your values
# ============================================================

# ----- LLM -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: Ollama local model (air-gapped deployment)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=codellama:34b

# ----- Database -----
DATABASE_URL=postgresql+asyncpg://codeguardian:codeguardian@localhost:5432/codeguardian

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0

# ----- File Storage (MinIO / AWS S3) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=codeguardian
S3_REGION=us-east-1

# ----- Authentication -----
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ----- Static Analyzers -----
ANALYZER_SEMGREP_ENABLED=true
ANALYZER_BANDIT_ENABLED=true
ANALYZER_ESLINT_ENABLED=true
ANALYZER_STATICCHECK_ENABLED=true
ANALYZER_CLIPPY_ENABLED=false

SEMGREP_RULES=p/owasp-top-ten,p/secrets,p/python,p/typescript

# ----- Quality Gate -----
QUALITY_GATE_ENABLED=false
QUALITY_GATE_FAIL_ON_CRITICAL=1
QUALITY_GATE_FAIL_ON_HIGH=10

# ----- Git Platforms -----
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_TOKEN=
BITBUCKET_WEBHOOK_SECRET=

# ----- App -----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ----- Celery -----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
